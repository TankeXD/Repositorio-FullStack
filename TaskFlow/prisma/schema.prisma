generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Board {
  id      String   @id @default(uuid())
  name    String
  columns Column[]
}

model Column {
  id      String @id @default(uuid())
  name    String
  order   Int
  board   Board  @relation(fields: [boardId], references: [id])
  boardId String
  tasks   Task[]
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  order       Int
  column      Column   @relation(fields: [columnId], references: [id])
  columnId    String
}
